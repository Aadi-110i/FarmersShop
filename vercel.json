{
    "version": 2,
    "framework": null,
    "installCommand": "npm install",
    "buildCommand": "npm run build",
    "outputDirectory": ".",
    "rewrites": [
        {
            "source": "/build/(.*)",
            "destination": "/public/build/$1"
        },
        {
            "source": "/(css|js|images|videos|favicon.ico|robots.txt)/(.*)",
            "destination": "/public/$1/$2"
        },
        {
            "source": "/favicon.ico",
            "destination": "/public/favicon.ico"
        },
        {
            "source": "/robots.txt",
            "destination": "/public/robots.txt"
        },
        {
            "source": "/(.*)",
            "destination": "/api/index.php"
        }
    ],
    "functions": {
        "api/*.php": {
            "runtime": "vercel-php@0.9.0"
        }
    },
    "env": {
        "APP_ENV": "production",
        "APP_DEBUG": "false",
        "APP_URL": "https://farmers-shop-main.vercel.app",
        "VERCEL": "1",
        "VIEW_COMPILED_PATH": "/tmp/storage/framework/views",
        "CACHE_STORE": "array",
        "SESSION_DRIVER": "cookie",
        "LOG_CHANNEL": "stderr",
        "DB_CONNECTION": "pgsql",
        "DB_HOST": "ep-plain-field-aqp7gyqk.c-8.us-east-1.aws.neon.tech",
        "DB_PORT": "5432",
        "DB_DATABASE": "neondb",
        "DB_USERNAME": "neondb_owner",
        "DB_SSLMODE": "require",
        "QUEUE_CONNECTION": "sync",
        "FILESYSTEM_DISK": "local",
        "APP_SERVICES_CACHE": "/tmp/cache/services.php",
        "APP_PACKAGES_CACHE": "/tmp/cache/packages.php",
        "APP_CONFIG_CACHE": "/tmp/cache/config.php",
        "APP_ROUTES_CACHE": "/tmp/cache/routes-v7.php",
        "APP_EVENTS_CACHE": "/tmp/cache/events.php"
    }
}